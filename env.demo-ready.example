# Copy this file to .env for a local demo profile, then replace local passwords.
# Tavily and Gemini keys are optional for the demo-real provider because fallback stays enabled.
DATABASE_URL=postgresql://plagcheck:replace-with-local-postgres-password@localhost:5432/plagcheck
POSTGRES_USER=plagcheck
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=plagcheck
POSTGRES_PORT=5432

MINIO_ROOT_USER=plagcheck-minio-admin
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=plagcheck-documents
MINIO_ACCESS_KEY=plagcheck-minio-admin
MINIO_SECRET_KEY=replace-with-local-minio-password

APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-local-session-secret-at-least-32-characters

SEED_SUPER_ADMIN_EMAIL=superadmin@plagcheck.local
SEED_SUPER_ADMIN_PASSWORD=replace-with-local-seed-password
SEED_DEMO_USER_PASSWORD=replace-with-local-demo-user-password

SCAN_PROVIDER=demo-real
DEMO_MODE=true
SHOW_PROVIDER_LABEL=true
ALLOW_FALLBACK=true

DEMO_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=PASTE_YOUR_TAVILY_KEY_HERE
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_MAX_CHUNKS=6

DEMO_AI_PROVIDER=gemini
DEMO_AI_DETECTION_MODE=llm
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=1200

DEMO_ACADEMIC_PROVIDER=openalex
OPENALEX_API_KEY=optional
OPENALEX_MAILTO=your-email@example.com
OPENALEX_MAX_RESULTS=5

DEMO_GRAMMAR_PROVIDER=languagetool-public
LANGUAGETOOL_URL=https://api.languagetool.org/v2/check
LANGUAGETOOL_LANGUAGE=en-US
LANGUAGETOOL_MAX_CHARS=20000

MAX_FILE_MB=25
MAX_WORDS_PER_DOCUMENT=50000
MONTHLY_WORD_LIMIT=1000000
ACCEPTED_FILES=pdf,doc,docx,txt

# =========================
# FEATURE BUDGETS / RATE LIMITS
# Dashboard must show feature names, not API names.
# =========================
FEATURE_BUDGETS_ENABLED=true
FEATURE_RATE_LIMITS_ENABLED=true
FEATURE_USAGE_DASHBOARD_ENABLED=true
MONTHLY_FULL_CHECK_LIMIT=300
MONTHLY_WORD_LIMIT=1000000
MONTHLY_FILE_LIMIT=300
MONTHLY_DEEP_CHECK_LIMIT=50
WEB_SOURCE_MATCHING_MONTHLY_UNITS=900
WEB_SOURCE_MATCHING_DAILY_UNITS=30
WEB_SOURCE_MATCHING_PER_MINUTE_UNITS=5
WEB_SOURCE_MATCHING_STANDARD_UNITS_PER_SCAN=3
WEB_SOURCE_MATCHING_DEEP_UNITS_PER_SCAN=6
WEB_SOURCE_MATCHING_RESERVE_UNITS=100
AI_WRITING_ANALYSIS_MONTHLY_REQUESTS=300
AI_WRITING_ANALYSIS_DAILY_REQUESTS=50
AI_WRITING_ANALYSIS_RPM=10
AI_WRITING_ANALYSIS_STANDARD_REQUESTS_PER_SCAN=1
AI_WRITING_ANALYSIS_MAX_INPUT_TOKENS=8000
AI_WRITING_ANALYSIS_MAX_OUTPUT_TOKENS=1024
AI_WRITING_ANALYSIS_MAX_TOTAL_TOKENS_PER_SCAN=9024
ACADEMIC_SOURCE_MONTHLY_UNITS=600
ACADEMIC_SOURCE_DAILY_UNITS=90
ACADEMIC_SOURCE_PER_MINUTE_UNITS=20
ACADEMIC_SOURCE_STANDARD_UNITS_PER_SCAN=2
ACADEMIC_SOURCE_DEEP_UNITS_PER_SCAN=3
GRAMMAR_REVIEW_MONTHLY_CHARACTERS=5400000
GRAMMAR_REVIEW_DAILY_CHARACTERS=180000
GRAMMAR_REVIEW_PER_MINUTE_CHARACTERS=54000
GRAMMAR_REVIEW_STANDARD_CHARS_PER_SCAN=18000
GRAMMAR_REVIEW_DEEP_CHARS_PER_SCAN=36000
GRAMMAR_REVIEW_MAX_REQUESTS_PER_MINUTE=3
PDF_REPORT_MONTHLY_LIMIT=500
PDF_REPORT_DAILY_LIMIT=50
ALLOW_LOCAL_FALLBACK_WHEN_BUDGET_EXHAUSTED=true
SHOW_FALLBACK_BADGE=true
BLOCK_SCAN_WHEN_ALL_FEATURE_BUDGETS_EXHAUSTED=true
DEFAULT_SCAN_MODE=standard
ENABLE_DEEP_SCAN=true
ENABLE_BUDGET_PREVIEW_BEFORE_SCAN=true
